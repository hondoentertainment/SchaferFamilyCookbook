{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "postinstall": "node scripts/sync-recipes-for-api.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "node scripts/sync-recipes-for-api.mjs && vitest run",
    "test:rules": "vitest run --config vitest.rules.config.ts",
    "test:coverage": "node scripts/sync-recipes-for-api.mjs && vitest run --coverage",
    "test:bundle-size": "node scripts/check-bundle-size.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:desktop": "playwright test --project=chromium",
    "lint": "eslint src api --report-unused-disable-directives --max-warnings 130",
    "lint:fix": "eslint src api --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "ci": "npm run lint && npm run type-check && npm run test:coverage && npm run build && npm run test:bundle-size",
    "images:dry-run": "node scripts/generate-imagen-images.mjs --dry-run --missing-only",
    "images:batch": "node scripts/generate-imagen-images.mjs --missing-only --limit 20",
    "images:resume": "node scripts/generate-imagen-images.mjs --missing-only --limit 20 --resume",
    "images:rebuild:fallback": "node scripts/rebuild-recipe-images.mjs --force-all --fallback-only --clean-old-generated",
    "images:generate:local": "node scripts/generate-recipe-derived-local-images.mjs",
    "images:apply:realistic-temp": "node scripts/apply-realistic-temporary-images.mjs && node scripts/sync-recipes-for-api.mjs",
    "images:verify": "node scripts/verify-recipe-images.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "lighthouse:ci": "npx --yes @lhci/cli@0.14.0 autorun",
    "deploy": "node scripts/deploy-all.mjs",
    "deploy:prod": "node scripts/deploy-all.mjs",
    "backup:recipes": "node scripts/backup-recipes-json.mjs",
    "admin:set-claim": "node scripts/set-admin-claim.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@sentry/react": "^9.47.1",
    "busboy": "^1.6.0",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.34.5",
    "twilio": "^5.12.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vercel/node": "^5.5.27",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.3.7",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "svgo": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.5"
  }
}
