rules_version = '2';

/**
 * Public read; uploads/deletes only for Firebase users with custom claim admin: true.
 * @see docs/FIREBASE_SECURITY.md
 */
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /recipes/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
