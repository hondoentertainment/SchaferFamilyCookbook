rules_version = '2';

/**
 * Public read; uploads/deletes only for Firebase users with custom claim admin: true.
 * @see docs/FIREBASE_SECURITY.md
 */
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Only allow image and video MIME types
    function isAllowedContentType() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*');
    }

    // Max 25 MB for images
    function isImageWithinSizeLimit() {
      return request.resource.contentType.matches('image/.*')
          && request.resource.size < 25 * 1024 * 1024;
    }

    // Max 100 MB for videos
    function isVideoWithinSizeLimit() {
      return request.resource.contentType.matches('video/.*')
          && request.resource.size < 100 * 1024 * 1024;
    }

    function isValidUpload() {
      return isAllowedContentType()
          && (isImageWithinSizeLimit() || isVideoWithinSizeLimit());
    }

    // Only allow uploads into expected directories
    match /recipe-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidUpload();
    }
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidUpload();
    }
  }
}
