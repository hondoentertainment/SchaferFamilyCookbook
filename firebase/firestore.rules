rules_version = '2';

/**
 * Public read-only archive: anyone can read; writes require Firebase Auth + custom claim `admin: true`.
 *
 * Set claims with Admin SDK, e.g. npm run admin:set-claim -- <uid>
 * Twilio MMS webhook uses Admin SDK and bypasses these rules.
 *
 * @see docs/FIREBASE_SECURITY.md
 */
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /recipes/{recipeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /trivia/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /gallery/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /contributors/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /history/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /config/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * Per-user preferences (favorites + ratings) keyed by display-name slug.
     *
     * This app uses a custom name-based identity (see src/App.tsx / 'schafer_user');
     * only custodians have Firebase Auth. For non-custodians we cannot match
     * request.auth.uid to the slug, so writes are open within this collection.
     * The data stored here is low-risk personalization (not secrets). Reads are
     * allowed for everyone to unblock future social features (e.g. aggregate
     * ratings). Custodians (admin) retain full control for moderation.
     *
     * Shape: { favorites: string[], ratings: map<recipeId, int 1-5>, collections: list, mealPlan: list, updatedAt: Timestamp }
     */
    match /userPrefs/{userId} {
      allow read: if true;
      allow create, update: if
        isAdmin() ||
        (
          request.resource.data.keys().hasOnly(['favorites', 'ratings', 'collections', 'mealPlan', 'updatedAt']) &&
          (
            !('favorites' in request.resource.data) ||
            request.resource.data.favorites is list
          ) &&
          (
            !('ratings' in request.resource.data) ||
            request.resource.data.ratings is map
          ) &&
          (
            !('collections' in request.resource.data) ||
            request.resource.data.collections is list
          ) &&
          (
            !('mealPlan' in request.resource.data) ||
            request.resource.data.mealPlan is list
          )
        );
      allow delete: if isAdmin();
    }

    // Family trivia leaderboard: world-readable (public within site),
    // append-only creates with shape validation. No update/delete from client.
    match /triviaScores/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() > 0 &&
        request.resource.data.displayName.size() <= 80 &&
        request.resource.data.userId is string &&
        request.resource.data.score is number &&
        request.resource.data.total is number &&
        request.resource.data.total > 0 &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= request.resource.data.total &&
        request.resource.data.completedAt == request.time;
      allow update, delete: if false;
    }

    /**
     * Recipe version snapshots written server-side whenever an admin saves a recipe.
     * Admins can read version history; no client-side writes.
     *
     * Shape: snapshot of the full recipe document at the time of the save, plus
     * { savedAt: Timestamp, savedBy: string }
     */
    match /recipe_versions/{recipeId}/versions/{versionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FCM push-notification tokens: no public read (token privacy).
    // Any authenticated request — or any caller supplying the required shape —
    // may register a token. No client-side update/delete (admin only).
    match /fcm_tokens/{tokenId} {
      allow read: if false;
      allow create: if
        request.auth != null ||
        (
          request.resource.data.token is string &&
          request.resource.data.userName is string
        );
      allow update, delete: if isAdmin();
    }

    // Analytics events: append-only observability log.
    // No public read; creates are open (low-risk); no update/delete from client.
    match /analytics_events/{eventId} {
      allow read: if false;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
