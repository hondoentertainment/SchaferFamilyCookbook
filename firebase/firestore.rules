rules_version = '2';

/**
 * Public read-only archive: anyone can read; writes require Firebase Auth + custom claim `admin: true`.
 *
 * Set claims with Admin SDK, e.g. npm run admin:set-claim -- <uid>
 * Twilio MMS webhook uses Admin SDK and bypasses these rules.
 *
 * @see docs/FIREBASE_SECURITY.md
 */
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /recipes/{recipeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /trivia/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /gallery/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /contributors/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /history/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /config/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    /**
     * Trivia scores — family-wide leaderboard.
     * Anyone can submit a score; only admins can prune or edit.
     * App enforces MAX_ENTRIES client-side.
     */
    match /triviaScores/{id} {
      allow read: if true;
      allow create: if request.resource.data.playerName is string
                    && request.resource.data.score is number
                    && request.resource.data.totalQuestions is number
                    && request.resource.data.percentage is number
                    && request.resource.data.timestamp is string;
      allow update, delete: if isAdmin();
    }
  }
}
