# Copy to `.env.production.local` or set in Vercel → Environment Variables.
# Do not commit real secrets except Firebase web API keys (public by design).

VITE_SHARE_BASE=https://schafer-family-cookbook.vercel.app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=schafer-cookbook
VITE_FIREBASE_AUTH_DOMAIN=schafer-cookbook.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=schafer-cookbook.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FCM_VAPID_KEY=

VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1

# Optional — Firebase App Check (reCAPTCHA v3 site key from Firebase Console → App Check)
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Set to true after Firebase Storage is enabled for family gallery uploads
VITE_GALLERY_UPLOADS_ENABLED=true

# Optional — must match NOTIFY_SECRET on Vercel for admin/gallery push from the client
VITE_NOTIFY_SECRET=

# Twilio MMS number (E.164, e.g. +15551234567) — shown on Gallery tab for text-to-gallery
VITE_ARCHIVE_PHONE=

# Optional — enables source map upload during `vite build` (set in Vercel, not in client bundle)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
