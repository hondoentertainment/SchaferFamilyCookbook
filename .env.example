# ── Client-side (Vite) ──────────────────────────────────────────
# Sentry DSN for error monitoring (optional, production only)
VITE_SENTRY_DSN=
# Comma-separated super admin names/emails (e.g. "kyle,admin@example.com")
VITE_SUPER_ADMINS=

# ── Server-side (Vercel Functions) ──────────────────────────────
# Google Gemini API key (required for AI features: image generation, magic import)
GEMINI_API_KEY=
# Set to "1" to disable per-IP rate limiting on the Gemini endpoint
GEMINI_RATE_LIMIT_DISABLED=

# Firebase Admin service account JSON (required for Twilio webhook → Firestore)
FIREBASE_SERVICE_ACCOUNT=

# Twilio credentials (required for MMS webhook signature validation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
