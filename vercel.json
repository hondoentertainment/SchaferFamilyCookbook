{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/share/recipe/:id", "destination": "/api/share?id=:id" },
    { "source": "/((?!api/|share/).*)", "destination": "/index.html" }
  ]
}
